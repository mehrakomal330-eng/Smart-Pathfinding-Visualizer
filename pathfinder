import tkinter as tk
from collections import deque
import time

ROWS = 20
COLS = 20
CELL_SIZE = 25

start = None
end = None
dragging = None
grid = []

root = tk.Tk()
root.title("Pathfinding Visualizer (BFS + DFS)")

canvas = tk.Canvas(root, width=COLS*CELL_SIZE, height=ROWS*CELL_SIZE)
canvas.pack()

cell_type = [["empty"]*COLS for _ in range(ROWS)]

# Draw grid
for r in range(ROWS):
    row = []
    for c in range(COLS):
        rect = canvas.create_rectangle(
            c*CELL_SIZE, r*CELL_SIZE,
            (c+1)*CELL_SIZE, (r+1)*CELL_SIZE,
            fill="white", outline="gray"
        )
        row.append(rect)
    grid.append(row)

# Click
def left_click(event):
    global start, end, dragging
    r, c = event.y // CELL_SIZE, event.x // CELL_SIZE

    if not start:
        start = (r, c)
        canvas.itemconfig(grid[r][c], fill="green")
        cell_type[r][c] = "start"

    elif not end:
        end = (r, c)
        canvas.itemconfig(grid[r][c], fill="red")
        cell_type[r][c] = "end"

    elif (r, c) == start:
        dragging = "start"
    elif (r, c) == end:
        dragging = "end"
    else:
        if cell_type[r][c] == "empty":
            canvas.itemconfig(grid[r][c], fill="black")
            cell_type[r][c] = "wall"

def drag(event):
    global start, end
    if not dragging:
        return

    r, c = event.y // CELL_SIZE, event.x // CELL_SIZE

    if dragging == "start":
        canvas.itemconfig(grid[start[0]][start[1]], fill="white")
        start = (r, c)
        canvas.itemconfig(grid[r][c], fill="green")

    elif dragging == "end":
        canvas.itemconfig(grid[end[0]][end[1]], fill="white")
        end = (r, c)
        canvas.itemconfig(grid[r][c], fill="red")

def stop_drag(event):
    global dragging
    dragging = None

# Right click erase
def right_click(event):
    global start, end
    r, c = event.y // CELL_SIZE, event.x // CELL_SIZE

    canvas.itemconfig(grid[r][c], fill="white")
    cell_type[r][c] = "empty"

    if (r, c) == start:
        start = None
    if (r, c) == end:
        end = None

canvas.bind("<Button-1>", left_click)
canvas.bind("<B1-Motion>", drag)
canvas.bind("<ButtonRelease-1>", stop_drag)
canvas.bind("<Button-3>", right_click)

# Draw path
def draw_path(parent):
    curr = end
    path_len = 0
    while curr != start:
        curr = parent.get(curr)
        if not curr:
            break
        if curr != start:
            r, c = curr
            canvas.itemconfig(grid[r][c], fill="yellow")
            path_len += 1
            root.update()
            time.sleep(0.05)
    return path_len

# BFS
def bfs():
    run_algo("BFS")

# DFS
def dfs():
    run_algo("DFS")

def run_algo(mode):
    if not start or not end:
        status.config(text="❌ Set Start & End")
        return

    start_time = time.time()

    if mode == "BFS":
        structure = deque([start])
        pop = structure.popleft
        push = structure.append
        color = "skyblue"
    else:
        structure = [start]
        pop = structure.pop
        push = structure.append
        color = "orange"

    visited = set([start])
    parent = {}
    steps = 0

    while structure:
        current = pop()
        steps += 1

        if current == end:
            break

        r, c = current

        neighbors = [(r+1,c),(r-1,c),(r,c+1),(r,c-1)]

        for nr, nc in neighbors:
            if 0 <= nr < ROWS and 0 <= nc < COLS:
                if (nr, nc) not in visited and cell_type[nr][nc] != "wall":
                    push((nr, nc))
                    visited.add((nr, nc))
                    parent[(nr, nc)] = current

                    if (nr, nc) != end:
                        canvas.itemconfig(grid[nr][nc], fill=color)
                        root.update()
                        time.sleep(speed.get()/100)

    path_len = draw_path(parent)
    end_time = time.time()

    status.config(f"{mode} | Steps:{steps} | Path:{path_len} | Time:{round(end_time-start_time,2)}s")

# Reset path only
def reset_path():
    for r in range(ROWS):
        for c in range(COLS):
            if cell_type[r][c] not in ["start","end","wall"]:
                canvas.itemconfig(grid[r][c], fill="white")

# Clear all
def clear_all():
    global start, end
    start, end = None, None
    for r in range(ROWS):
        for c in range(COLS):
            canvas.itemconfig(grid[r][c], fill="white")
            cell_type[r][c] = "empty"

# UI
frame = tk.Frame(root)
frame.pack()

tk.Button(frame, text="BFS", command=bfs, bg="lightblue").pack(side="left", padx=5)
tk.Button(frame, text="DFS", command=dfs, bg="orange").pack(side="left", padx=5)
tk.Button(frame, text="Reset Path", command=reset_path).pack(side="left", padx=5)
tk.Button(frame, text="Clear All", command=clear_all, bg="red").pack(side="left", padx=5)

speed = tk.Scale(root, from_=1, to=50, orient="horizontal", label="Speed")
speed.set(10)
speed.pack()

status = tk.Label(root, text="Ready")
status.pack()

root.mainloop()
